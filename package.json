{
  "name": "goo",
  "version": "1.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Local Odoo development helper — stdlib Python server + Owl 3 frontend (no bundler; modules are served as-is).",
  "scripts": {
    "format": "prettier --write \"static/**/*.{js,css,html}\" \"*.md\"",
    "format:check": "prettier --check \"static/**/*.{js,css,html}\" \"*.md\"",
    "lint": "eslint static/src",
    "lint:fix": "eslint static/src --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0"
  }
}
